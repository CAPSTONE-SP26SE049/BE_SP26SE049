| `role_code` | VARCHAR(20) | NOT NULL default `USER` |
| `phone` | VARCHAR(20) | |
| `region` | VARCHAR(20) | |
| `email_verified` | BOOLEAN | NOT NULL default `false` |
| `email_verify_code` | VARCHAR(6) | |
