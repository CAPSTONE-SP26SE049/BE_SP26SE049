<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="17-standardize-challenge-quiz-centralization" author="antigravity">
        <!-- Add missing columns to challenge table -->
        <addColumn tableName="challenge">
            <column name="skill_type" type="VARCHAR(50)"/>
            <column name="difficulty" type="VARCHAR(20)"/>
        </addColumn>

        <!-- Update challenge table: mark 'type' as nullable as it is deprecated -->
        <dropNotNullConstraint tableName="challenge" columnName="type"/>

        <!-- Add challenge_id to quiz_question to link to the centralized question bank -->
        <addColumn tableName="quiz_question">
            <column name="challenge_id" type="UUID"/>
        </addColumn>

        <addForeignKeyConstraint baseColumnNames="challenge_id"
                                 baseTableName="quiz_question"
                                 constraintName="fk_quiz_question_challenge"
                                 referencedColumnNames="id"
                                 referencedTableName="challenge"
                                 onDelete="SET NULL"/>

        <!-- Cleanup: remove content_data from quiz_question as data is now in challenge -->
        <dropColumn tableName="quiz_question" columnName="content_data"/>
    </changeSet>

</databaseChangeLog>
