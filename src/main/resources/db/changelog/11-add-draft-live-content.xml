<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260305-add-draft-live-columns" author="antigravity">
        <!-- Level -->
        <addColumn tableName="level">
            <column name="parent_id" type="UUID"/>
            <column name="draft_id" type="UUID"/>
        </addColumn>
        <addForeignKeyConstraint baseTableName="level" baseColumnNames="parent_id" constraintName="fk_level_parent" referencedTableName="level" referencedColumnNames="id"/>
        <addForeignKeyConstraint baseTableName="level" baseColumnNames="draft_id" constraintName="fk_level_draft" referencedTableName="level" referencedColumnNames="id"/>

        <!-- Challenge -->
        <addColumn tableName="challenge">
            <column name="parent_id" type="UUID"/>
            <column name="draft_id" type="UUID"/>
        </addColumn>
        <addForeignKeyConstraint baseTableName="challenge" baseColumnNames="parent_id" constraintName="fk_challenge_parent" referencedTableName="challenge" referencedColumnNames="id"/>
        <addForeignKeyConstraint baseTableName="challenge" baseColumnNames="draft_id" constraintName="fk_challenge_draft" referencedTableName="challenge" referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
