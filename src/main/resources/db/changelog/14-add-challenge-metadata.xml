<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260311-add-challenge-metadata" author="assistant">
        <addColumn tableName="challenge">
            <column name="metadata" type="jsonb" defaultValueComputed="'{}'::jsonb">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <setColumnRemarks tableName="challenge"
                          columnName="metadata"
                          remarks="Flexible structure for challenge types: READING stores wrong_index, correction; WRITING stores accepted_answers"/>
    </changeSet>

</databaseChangeLog>
