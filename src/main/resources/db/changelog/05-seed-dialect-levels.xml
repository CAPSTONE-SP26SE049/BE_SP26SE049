<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260225-seed-dialects" author="antigravity">
        <insert tableName="dialect">
            <column name="id" value="00000000-0000-0000-0001-000000000001"/>
            <column name="name" value="NORTH"/>
            <column name="description" value="Northern Vietnamese Dialect"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>
        <insert tableName="dialect">
            <column name="id" value="00000000-0000-0000-0001-000000000002"/>
            <column name="name" value="CENTRAL"/>
            <column name="description" value="Central Vietnamese Dialect"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>
        <insert tableName="dialect">
            <column name="id" value="00000000-0000-0000-0001-000000000003"/>
            <column name="name" value="SOUTH"/>
            <column name="description" value="Southern Vietnamese Dialect"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>
    </changeSet>

    <changeSet id="20260225-seed-sample-levels" author="antigravity">
        <!-- Sample levels for SOUTH -->
        <insert tableName="level">
            <column name="id" valueComputed="uuid_generate_v4()"/>
            <column name="dialect_id" value="00000000-0000-0000-0001-000000000003"/>
            <column name="level_order" value="1"/>
            <column name="name" value="Chào hỏi cơ bản (Nam)"/>
            <column name="description" value="Học cách chào hỏi với giọng miền Nam"/>
            <column name="min_stars_required" value="0"/>
            <column name="ai_threshold" value="70"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>
        <insert tableName="level">
            <column name="id" valueComputed="uuid_generate_v4()"/>
            <column name="dialect_id" value="00000000-0000-0000-0001-000000000003"/>
            <column name="level_order" value="2"/>
            <column name="name" value="Số đếm (Nam)"/>
            <column name="description" value="Cách phát âm các con số giọng miền Nam"/>
            <column name="min_stars_required" value="3"/>
            <column name="ai_threshold" value="75"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>
    </changeSet>

</databaseChangeLog>
